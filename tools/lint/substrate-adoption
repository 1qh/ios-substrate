#!/usr/bin/env python3
"""Reject copied substrate-owned Swift primitives in consumer app roots."""

from __future__ import annotations

import argparse
import os
import pathlib
import re
import sys
import tempfile

SKIP_DIRS = {".git", ".build", ".swiftpm", "build", "DerivedData", "node_modules", "Pods"}
SWIFT_EXTENSION = ".swift"
ALLOW = re.compile(r"substrate-adoption-allow:")
PATTERNS: list[tuple[str, re.Pattern[str], str]] = [
    (
        "local FlowLayout copy",
        re.compile(r"\bstruct\s+FlowLayout\s*:\s*Layout\b"),
        "IOSSubstrate.FlowLayout",
    ),
    (
        "local PressScaleButtonStyle copy",
        re.compile(r"\bstruct\s+PressScaleButtonStyle\s*:\s*ButtonStyle\b"),
        "IOSSubstrate PressScaleButtonStyle or .pressScale()",
    ),
    (
        "local ShimmerView copy",
        re.compile(r"\bstruct\s+ShimmerView\s*:\s*View\b"),
        "IOSSubstrate.ShimmerView",
    ),
    (
        "raw impact haptic generator",
        re.compile(r"\bUIImpactFeedbackGenerator\s*\("),
        "IOSSubstrate.HapticFeedback",
    ),
    (
        "raw notification haptic generator",
        re.compile(r"\bUINotificationFeedbackGenerator\s*\("),
        "IOSSubstrate.HapticFeedback",
    ),
    (
        "raw selection haptic generator",
        re.compile(r"\bUISelectionFeedbackGenerator\s*\("),
        "IOSSubstrate.HapticFeedback",
    ),
    (
        "direct LocalAuthentication context construction",
        re.compile(r"\bLAContext\s*\("),
        "IOSSubstrate.BiometricAuthentication",
    ),
    (
        "direct biometric capability policy",
        re.compile(r"\.canEvaluatePolicy\s*\("),
        "IOSSubstrate.BiometricAuthentication",
    ),
    (
        "direct biometric evaluation policy",
        re.compile(r"\.evaluatePolicy\s*\("),
        "IOSSubstrate.BiometricAuthentication",
    ),
    (
        "local base64url codec wrapper",
        re.compile(r"\b(?:enum|struct|class)\s+Base64URL\b"),
        "IOSSubstrate.Base64URL",
    ),
    (
        "local internet date codec wrapper",
        re.compile(r"\b(?:enum|struct|class)\s+(?:ISO8601|ISO8601DateCodec)\b"),
        "IOSSubstrate.ISO8601DateCodec",
    ),



    (
        "local DisplayString copy",
        re.compile(r"\benum\s+DisplayString\s*:"),
        "IOSSubstrate.DisplayString",
    ),
    (
        "local DisplayStringConvertible copy",
        re.compile(r"\bprotocol\s+DisplayStringConvertible\b"),
        "IOSSubstrate.DisplayStringConvertible",
    ),
    (
        "local LoadState state-machine copy",
        re.compile(r"\benum\s+LoadState\s*<"),
        "IOSSubstrate.LoadState",
    ),
    (
        "local SubmitError copy",
        re.compile(r"\b(?:struct|enum|class)\s+SubmitError\b"),
        "IOSSubstrate.SubmitError",
    ),
    (
        "local submit error alert binding",
        re.compile(r"\bfunc\s+errorAlert\s*\(\s*_\s+\w+\s*:\s*Binding\s*<\s*SubmitError\?\s*>"),
        "IOSSubstrate View.errorAlert",
    ),

    (
        "local adaptive symbol effect kind copy",
        re.compile(r"\b(?:enum|struct)\s+TCSymbolEffectKind\b"),
        "IOSSubstrate.AdaptiveSymbolEffectKind",
    ),
    (
        "local adaptive glass modifier",
        re.compile(r"\bfunc\s+tcGlass\s*\("),
        "IOSSubstrate View.adaptiveGlass",
    ),
    (
        "local adaptive prominent glass button style modifier",
        re.compile(r"\bfunc\s+tcProminentGlassButtonStyle\s*\("),
        "IOSSubstrate View.adaptiveProminentGlassButtonStyle",
    ),
    (
        "local adaptive glass button style modifier",
        re.compile(r"\bfunc\s+tcGlassButtonStyle\s*\("),
        "IOSSubstrate View.adaptiveGlassButtonStyle",
    ),
    (
        "local adaptive symbol effect modifier",
        re.compile(r"\bfunc\s+tcSymbolEffect\s*\("),
        "IOSSubstrate View.adaptiveSymbolEffect",
    ),
    (
        "local adaptive numeric text transition modifier",
        re.compile(r"\bfunc\s+tcNumericTextTransition\s*\("),
        "IOSSubstrate View.adaptiveNumericTextTransition",
    ),
    (
        "local adaptive symbol replace transition modifier",
        re.compile(r"\bfunc\s+tcSymbolReplace(?:Up)?Transition\s*\("),
        "IOSSubstrate View adaptive symbol replace transitions",
    ),
    (
        "local internet date formatter options",
        re.compile(r"\.withInternetDateTime\b"),
        "IOSSubstrate.ISO8601DateCodec",
    ),
    (
        "direct UIApplication URL open",
        re.compile(r"\bUIApplication\.shared\.open\s*\("),
        "IOSSubstrate.ExternalURLOpener",
    ),
]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Detect copied substrate-owned Swift UI primitives in consumer apps.")
    parser.add_argument("paths", nargs="*", default=["."], help="Swift files or directories to scan")
    parser.add_argument("--selftest", action="store_true")
    return parser.parse_args()


def swift_files(path: pathlib.Path) -> list[pathlib.Path]:
    if path.is_file():
        return [path] if path.suffix == SWIFT_EXTENSION else []
    if not path.is_dir():
        return []
    files: list[pathlib.Path] = []
    for root, dirs, names in os.walk(path):
        dirs[:] = [directory for directory in dirs if directory not in SKIP_DIRS and not directory.startswith(".")]
        root_path = pathlib.Path(root)
        for name in names:
            candidate = root_path / name
            if candidate.suffix == SWIFT_EXTENSION:
                files.append(candidate)
    return files


def active_code_line(line: str, in_block_comment: bool) -> tuple[str, bool]:
    result: list[str] = []
    index = 0
    while index < len(line):
        if in_block_comment:
            end = line.find("*/", index)
            if end == -1:
                return "".join(result), True
            index = end + 2
            in_block_comment = False
            continue
        block_start = line.find("/*", index)
        line_comment = line.find("//", index)
        if line_comment != -1 and (block_start == -1 or line_comment < block_start):
            result.append(line[index:line_comment])
            return "".join(result), False
        if block_start == -1:
            result.append(line[index:])
            return "".join(result), False
        result.append(line[index:block_start])
        index = block_start + 2
        in_block_comment = True
    return "".join(result), in_block_comment


def scan_text(text: str) -> list[str]:
    findings: list[str] = []
    in_block_comment = False
    for line_number, line in enumerate(text.splitlines(), start=1):
        if ALLOW.search(line):
            continue
        code, in_block_comment = active_code_line(line, in_block_comment)
        if not code.strip():
            continue
        for label, pattern, replacement in PATTERNS:
            if pattern.search(code):
                findings.append(f"{line_number}: {label}; use {replacement}")
                break
    return findings


def scan_paths(paths: list[str]) -> list[str]:
    files: list[pathlib.Path] = []
    for raw_path in paths:
        files.extend(swift_files(pathlib.Path(raw_path)))
    findings: list[str] = []
    for file in sorted(set(files)):
        try:
            text = file.read_text(errors="ignore")
        except OSError:
            continue
        for finding in scan_text(text):
            findings.append(f"{file}:{finding}")
    return findings


def selftest() -> None:
    bad = """
import SwiftUI
import LocalAuthentication
import UIKit

struct FlowLayout: Layout {}
struct PressScaleButtonStyle: ButtonStyle {
    func makeBody(configuration: Configuration) -> some View { configuration.label }
}
struct ShimmerView: View {
    var body: some View { Text("loading") }
}
enum Base64URL {
    static func decode(_ raw: String) -> Data? { nil }
}
func feedback() {
    let context = LAContext()
    UIImpactFeedbackGenerator(style: .light).impactOccurred()
    UINotificationFeedbackGenerator().notificationOccurred(.success)
    UISelectionFeedbackGenerator().selectionChanged()
    if context.canEvaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, error: nil) {}
    try await context.evaluatePolicy(.deviceOwnerAuthenticationWithBiometrics, localizedReason: "Unlock")
    UIApplication.shared.open(URL(string: "https://example.test")!)
    let formatter = ISO8601DateFormatter()
    formatter.formatOptions = [.withInternetDateTime, .withFractionalSeconds]
}
enum ISO8601 {
    static func parse(_ raw: String) -> Date? { nil }
}
enum DisplayString: Equatable {
    case userContent(String)
}
protocol DisplayStringConvertible {
    var displayString: DisplayString { get }
}
enum LoadState<Value: Sendable> {
    case idle
}
struct SubmitError: Identifiable {
    let id = UUID()
}
enum TCSymbolEffectKind { case bounce }
extension View {
    func errorAlert(_ error: Binding<SubmitError?>) -> some View { self }
    func tcGlass() -> some View { self }
    func tcProminentGlassButtonStyle() -> some View { self }
    func tcGlassButtonStyle() -> some View { self }
    func tcSymbolEffect(_ effect: TCSymbolEffectKind) -> some View { self }
    func tcNumericTextTransition() -> some View { self }
    func tcSymbolReplaceTransition() -> some View { self }
}
"""
    good = """
import IOSSubstrate
import SwiftUI

struct ConsumerView: View {
    var body: some View {
        FlowLayout { Text("A") }
            .pressScale()
            .onAppear { HapticFeedback.light() }
            .task { _ = ISO8601DateCodec.parseInternetDateTime("2026-05-26T05:30:12Z") }
            .overlay { ShimmerView().frame(height: 1) }
            .onSubmit { _ = Base64URL.decode("bWFw") }
            .errorAlert(.constant(nil))
            .adaptiveGlass()
            .adaptiveProminentGlassButtonStyle()
            .adaptiveGlassButtonStyle()
            .adaptiveSymbolEffect(.bounce)
            .adaptiveNumericTextTransition()
            .adaptiveSymbolReplaceTransition()
            .task {
                _ = DisplayString.userContent("typed")
                _ = LoadState<String, String>.loaded("ready").value
                ExternalURLOpener.open(URL(string: "https://example.test")!)
            }
    }
}
// UIImpactFeedbackGenerator(style: .heavy).impactOccurred()
/*
struct FlowLayout: Layout {}
*/
"""
    allow = "UIImpactFeedbackGenerator(style: .light).impactOccurred() // substrate-adoption-allow: platform probe\n"
    bad_findings = scan_text(bad)
    checks = [
        len(bad_findings) == len(PATTERNS),
        len(scan_text(good)) == 0,
        len(scan_text(allow)) == 0,
        all("IOSSubstrate" in finding for finding in bad_findings),
    ]
    with tempfile.TemporaryDirectory() as temporary_directory:
        temporary_path = pathlib.Path(temporary_directory)
        (temporary_path / "Bad.swift").write_text(bad)
        (temporary_path / "Good.swift").write_text(good)
        path_findings = scan_paths([str(temporary_path / "Bad.swift")])
        checks.append(len(path_findings) == len(PATTERNS))
    if not all(checks):
        print("FAIL: substrate-adoption selftest failed", file=sys.stderr)
        for finding in bad_findings:
            print(f"  {finding}", file=sys.stderr)
        sys.exit(1)
    print("ok")


def main() -> None:
    args = parse_args()
    if args.selftest:
        selftest()
        return
    findings = scan_paths(args.paths)
    if not findings:
        print("ok")
        return
    print("FAIL: copied substrate-owned Swift primitives:", file=sys.stderr)
    for finding in findings:
        print(f"  {finding}", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
