  local device="booted"
  local appearance=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      --appearance)
        shift
        appearance="${1:-}"
        ;;
      *) fail "unknown ui option: $1" ;;
    esac
    shift || true
  done
  require_value '--device' "$device"
  require_value '--appearance' "$appearance"
  case "$appearance" in
    light | dark) ;;
    *) fail '--appearance must be light or dark' ;;
  esac
  xcrun simctl ui "$device" appearance "$appearance"
}

log_show() {
  local device="booted"
  local predicate=""
  local last=""
  local info=0
  local style=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      --predicate)
        shift
        predicate="${1:-}"
        ;;
      --last)
        shift
        last="${1:-}"
        ;;
      --info)
        info=1
        ;;
      --style)
        shift
        style="${1:-}"
        ;;
      *) fail "unknown log-show option: $1" ;;
    esac
    shift || true
  done
  require_value '--device' "$device"
  require_value '--predicate' "$predicate"
  local args=(simctl spawn "$device" log show --predicate "$predicate")
  if [ "$info" -eq 1 ]; then
    args+=(--info)
  fi
  if [ -n "$last" ]; then
    args+=(--last "$last")
  fi
  if [ -n "$style" ]; then
    args+=(--style "$style")
  fi
  xcrun "${args[@]}"
}

log_stream() {
  local device="booted"
  local predicate=""
  local level=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      --predicate)
        shift
        predicate="${1:-}"
        ;;
      --level)
        shift
        level="${1:-}"
        ;;
      *) fail "unknown log-stream option: $1" ;;
    esac
    shift || true
  done
  require_value '--device' "$device"
  require_value '--predicate' "$predicate"
  local args=(simctl spawn "$device" log stream --predicate "$predicate")
  if [ -n "$level" ]; then
    args+=(--level "$level")
  fi
  xcrun "${args[@]}"
}

shutdown_device() {
  local device=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      *) fail "unknown shutdown option: $1" ;;
    esac
    shift || true
  done
  require_value '--device' "$device"
  xcrun simctl shutdown "$device" >/dev/null 2>&1 || true
}

