  require_value '--device' "$device"
  xcrun simctl bootstatus "$device" -b
}

app_container() {
  local bundle_id=""
  local device="booted"
  local kind="app"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle-id)
        shift
        bundle_id="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --type)
        shift
        kind="${1:-}"
        ;;
      *) fail "unknown app-container option: $1" ;;
    esac
    shift || true
  done
  require_value '--bundle-id' "$bundle_id"
  require_value '--device' "$device"
  case "$kind" in
    app | data | groups | group) ;;
    *) fail '--type must be app, data, groups, or group' ;;
  esac
  xcrun simctl get_app_container "$device" "$bundle_id" "$kind"
}

grant_privacy() {
  local bundle_id=""
  local device="booted"
  local service=""
  local timeout=10
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle-id)
        shift
        bundle_id="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --service)
        shift
        service="${1:-}"
        ;;
      --timeout)
        shift
        timeout="${1:-}"
        ;;
      *) fail "unknown privacy option: $1" ;;
    esac
    shift || true
  done
  require_value '--bundle-id' "$bundle_id"
  require_value '--device' "$device"
  require_value '--service' "$service"
  [[ "$timeout" =~ ^[0-9]+$ ]] || fail '--timeout must be a positive integer'
  xcrun simctl privacy "$device" grant "$service" "$bundle_id" >/dev/null 2>&1 &
  local pid=$!
  local deadline=$((SECONDS + timeout))
  while kill -0 "$pid" >/dev/null 2>&1; do
    if [ "$SECONDS" -ge "$deadline" ]; then
      kill "$pid" >/dev/null 2>&1 || true
      wait "$pid" >/dev/null 2>&1 || true
      return 0
    fi
    sleep 0.5
  done
  wait "$pid" >/dev/null 2>&1 || true
}

set_location() {
  local device="booted"
  local latlng=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      --latlng)
        shift
        latlng="${1:-}"
        ;;
      *) fail "unknown location option: $1" ;;
    esac
    shift || true
  done
  require_value '--device' "$device"
  require_value '--latlng' "$latlng"
  xcrun simctl location "$device" set "$latlng"
}

