        shift
        device="${1:-}"
        ;;
      *) fail "unknown terminate option: $1" ;;
    esac
    shift || true
  done
  require_value '--bundle-id' "$bundle_id"
  xcrun simctl terminate "$device" "$bundle_id" >/dev/null 2>&1 || true
}

