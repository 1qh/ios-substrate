  local device="booted"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --device)
        shift
        device="${1:-}"
        ;;
      *) fail "unknown keychain-reset option: $1" ;;
    esac
    shift || true
  done
  xcrun simctl keychain "$device" reset >/dev/null 2>&1 || true
}

push_payload() {
  local bundle_id=""
  local device="booted"
  local payload=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle-id)
        shift
        bundle_id="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --payload)
        shift
        payload="${1:-}"
        ;;
      *) fail "unknown push option: $1" ;;
    esac
    shift || true
  done
  require_value '--bundle-id' "$bundle_id"
  require_value '--payload' "$payload"
  [ -f "$payload" ] || fail "payload not found: $payload"
  xcrun simctl push "$device" "$bundle_id" "$payload"
}

nuke_all() {
  xcrun simctl shutdown all >/dev/null 2>&1 || true
  xcrun simctl erase all
}

case "${1:-}" in
  boot-wait)
    shift
    boot_wait "$@"
    ;;
  udid)
    shift
    sim_udid "$@"
    ;;
  booted-udid)
    shift
    booted_udid "$@"
    ;;
  create-if-needed)
    shift
    create_if_needed "$@"
    ;;
  list-devices)
    shift
    list_devices "$@"
    ;;
  install-launch)
    shift
    install_launch "$@"
    ;;
  install)
    shift
    install_app "$@"
    ;;
  launch)
    shift
    launch_app "$@"
    ;;
  terminate)
    shift
    terminate_app "$@"
    ;;
  uninstall)
    shift
    uninstall_app "$@"
    ;;
  bootstatus)
    shift
    bootstatus_device "$@"
    ;;
  app-container)
    shift
    app_container "$@"
    ;;
  privacy)
    shift
    grant_privacy "$@"
    ;;
  location)
    shift
    set_location "$@"
    ;;
  ui)
    shift
    set_ui "$@"
    ;;
  log-show)
    shift
    log_show "$@"
    ;;
  log-stream)
    shift
    log_stream "$@"
    ;;
  shutdown)
    shift
    shutdown_device "$@"
    ;;
  keychain-reset)
    shift
    keychain_reset "$@"
    ;;
  push)
    shift
    push_payload "$@"
    ;;
  nuke-all)
    shift
    [ "$#" -eq 0 ] || fail 'nuke-all does not accept options'
    nuke_all
    ;;
  codesign-app)
    shift
    codesign_app "$@"
    ;;
  help | --help | -h)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
