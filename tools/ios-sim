#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
ios-sim: product-neutral simulator helpers

Commands:
  boot-wait --name <simulator-name|udid> [--timeout <seconds>] [--open]
  udid --name <simulator-name>
  booted-udid [--name <simulator-name>]
  list-devices [--booted] [--json]
  create-if-needed --name <simulator-name> --device-type <CoreSimulator-device-type> [--runtime latest-ios|runtime-id]
  install-launch --app <app-path> --bundle-id <bundle-id> [--device <booted|name|udid>] [--codesign <always|retry|never>] [--launch-retries <count>] [--launch-retry-delay <seconds>]
  install --app <app-path> [--device <booted|name|udid>] [--codesign <always|retry|never>]
  launch --bundle-id <bundle-id> [--device <booted|name|udid>] [--terminate-running-process] [--console-pty] [--env KEY=VALUE...]
  terminate --bundle-id <bundle-id> [--device <booted|name|udid>]
  uninstall --bundle-id <bundle-id> [--device <booted|name|udid>]
  bootstatus [--device <booted|name|udid>]
  app-container --bundle-id <bundle-id> [--device <booted|name|udid>] [--type app|data|groups|group]
  privacy --service <service> --bundle-id <bundle-id> [--device <booted|name|udid>] [--timeout <seconds>]
  location --latlng <latitude,longitude> [--device <booted|name|udid>]
  ui --appearance <light|dark> [--device <booted|name|udid>]
  log-show --predicate <predicate> [--device <booted|name|udid>] [--last <duration>] [--info] [--style <style>]
  log-stream --predicate <predicate> [--device <booted|name|udid>] [--level <level>]
  shutdown --device <all|name|udid>
  keychain-reset [--device <booted|name|udid>]
  push --bundle-id <bundle-id> --payload <payload-path> [--device <booted|name|udid>]
  nuke-all
  codesign-app --app <app-path>

The script stores no product names, bundle identifiers, hosts, or account data.
USAGE
}

fail() {
  printf 'ios-sim: %s\n' "$1" >&2
  exit 1
}

require_value() {
  local name="$1"
  local value="${2:-}"
  [ -n "$value" ] || fail "$name is required"
}

require_tool() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required tool: $1"
}

latest_ios_runtime() {
  require_tool xcrun
  require_tool jq
  xcrun simctl list runtimes available -j \
    | jq -r '.runtimes[] | select(.platform == "iOS" and .isAvailable == true) | .identifier' \
    | tail -1
}

sim_udid() {
  local name="${IOS_SUBSTRATE_SIMULATOR_NAME:-}"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --name)
        shift
        name="${1:-}"
        ;;
      *) fail "unknown udid option: $1" ;;
    esac
    shift || true
  done
  require_value '--name' "$name"
  require_tool xcrun
  require_tool jq
  local udid
  udid="$(xcrun simctl list devices available -j \
    | jq -r --arg name "$name" '.devices[][] | select(.name == $name and .isAvailable == true) | .udid' \
    | head -1)"
  require_value "simulator not found: $name" "$udid"
  printf '%s\n' "$udid"
}

booted_udid() {
  local name="${IOS_SUBSTRATE_SIMULATOR_NAME:-}"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --name)
        shift
        name="${1:-}"
        ;;
      *) fail "unknown booted-udid option: $1" ;;
    esac
    shift || true
  done
  require_tool xcrun
  require_tool jq
  local udid
  if [ -n "$name" ]; then
    udid="$(xcrun simctl list devices booted -j \
      | jq -r --arg name "$name" '.devices[][] | select(.name == $name and .state == "Booted") | .udid' \
      | head -1)"
    require_value "booted simulator not found: $name" "$udid"
  else
    udid="$(xcrun simctl list devices booted -j \
      | jq -r '.devices[][] | select(.state == "Booted") | .udid' \
      | head -1)"
    require_value 'booted simulator' "$udid"
  fi
  printf '%s\n' "$udid"
}

list_devices() {
  local booted=0
  local json=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --booted)
        booted=1
        ;;
      --json)
        json=1
        ;;
      *) fail "unknown list-devices option: $1" ;;
    esac
    shift || true
  done
  require_tool xcrun
  local args=(simctl list devices)
  if [ "$booted" -eq 1 ]; then
    args+=(booted)
  fi
  if [ "$json" -eq 1 ]; then
    args+=(-j)
  fi
  xcrun "${args[@]}"
}

create_if_needed() {
  local name=""
  local device_type=""
  local runtime="latest-ios"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --name)
        shift
        name="${1:-}"
        ;;
      --device-type)
        shift
        device_type="${1:-}"
        ;;
      --runtime)
        shift
        runtime="${1:-}"
        ;;
      *) fail "unknown create-if-needed option: $1" ;;
    esac
    shift || true
  done
  require_value '--name' "$name"
  require_value '--device-type' "$device_type"
  require_tool xcrun
  require_tool jq
  local udid=""
  udid="$(xcrun simctl list devices available -j \
    | jq -r --arg name "$name" '.devices[][] | select(.name == $name and .isAvailable == true) | .udid' \
    | head -1)"
  if [ -n "$udid" ]; then
    printf '%s\n' "$udid"
    return
  fi
  if [ "$runtime" = "latest-ios" ]; then
    runtime="$(latest_ios_runtime)"
  fi
  require_value 'iOS runtime' "$runtime"
  xcrun simctl create "$name" "$device_type" "$runtime"
}

codesign_app() {
  local app=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app)
        shift
        app="${1:-}"
        ;;
      *) fail "unknown codesign-app option: $1" ;;
    esac
    shift || true
  done
  require_value '--app' "$app"
  [ -d "$app" ] || fail "app bundle not found: $app"
  require_tool codesign
  require_tool file
  find "$app" -type f -exec sh -c 'file "$1" | grep -q Mach-O && codesign --force --sign - --timestamp=none "$1" 2>/dev/null || true' _ {} \; || true
  codesign --force --sign - --timestamp=none "$app" 2>/dev/null || true
}

boot_wait() {
  local name="${IOS_SUBSTRATE_SIMULATOR_NAME:-}"
  local timeout=60
  local open_sim=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --name)
        shift
        name="${1:-}"
        ;;
      --device)
        shift
        name="${1:-}"
        ;;
      --timeout)
        shift
        timeout="${1:-}"
        ;;
      --open)
        open_sim=1
        ;;
      *) fail "unknown boot-wait option: $1" ;;
    esac
    shift || true
  done
  require_value '--name' "$name"
  [[ "$timeout" =~ ^[0-9]+$ ]] || fail '--timeout must be a positive integer'
  require_tool xcrun
  xcrun simctl boot "$name" >/dev/null 2>&1 || true
  if [ "$open_sim" -eq 1 ]; then
    open -a Simulator >/dev/null 2>&1 || true
  fi
  local deadline
  deadline=$(($(date +%s) + timeout))
  while ! xcrun simctl list devices booted 2>/dev/null | grep -Fq "$name"; do
    if [ "$(date +%s)" -gt "$deadline" ]; then
      fail "simulator boot timeout ${timeout}s for '$name'"
    fi
    sleep 1
  done
}

launch_app() {
  local bundle_id=""
  local device="booted"
  local terminate=0
  local console_pty=0
  local envs=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --bundle-id)
        shift
        bundle_id="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --terminate-running-process)
        terminate=1
        ;;
      --console-pty)
        console_pty=1
        ;;
      --env)
        shift
        envs+=("${1:-}")
        ;;
      *) fail "unknown launch option: $1" ;;
    esac
    shift || true
  done
  require_value '--bundle-id' "$bundle_id"
  require_value '--device' "$device"
  local args=(simctl launch)
  if [ "$terminate" -eq 1 ]; then
    args+=(--terminate-running-process)
  fi
  if [ "$console_pty" -eq 1 ]; then
    args+=(--console-pty)
  fi
  local env
  for env in "${envs[@]}"; do
    [[ "$env" == *=* ]] || fail '--env must be KEY=VALUE'
    args+=(--setenv "${env%%=*}" "${env#*=}")
  done
  args+=("$device" "$bundle_id")
  xcrun "${args[@]}"
}

install_launch() {
  local app=""
  local bundle_id=""
  local device="booted"
  local sign_mode="retry"
  local retries=8
  local retry_delay=3
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app)
        shift
        app="${1:-}"
        ;;
      --bundle-id)
        shift
        bundle_id="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --codesign)
        shift
        sign_mode="${1:-}"
        ;;
      --launch-retries)
        shift
        retries="${1:-}"
        ;;
      --launch-retry-delay)
        shift
        retry_delay="${1:-}"
        ;;
      *) fail "unknown install-launch option: $1" ;;
    esac
    shift || true
  done
  require_value '--app' "$app"
  require_value '--bundle-id' "$bundle_id"
  require_value '--device' "$device"
  [ -d "$app" ] || fail "app bundle not found: $app"
  [[ "$retries" =~ ^[0-9]+$ ]] || fail '--launch-retries must be a positive integer'
  [[ "$retry_delay" =~ ^[0-9]+$ ]] || fail '--launch-retry-delay must be a positive integer'
  case "$sign_mode" in
    always | retry | never) ;;
    *) fail '--codesign must be always, retry, or never' ;;
  esac
  require_tool xcrun
  if [ "$sign_mode" = 'always' ]; then
    codesign_app --app "$app"
  fi
  if ! xcrun simctl install "$device" "$app" >/dev/null 2>&1; then
    if [ "$sign_mode" = 'retry' ]; then
      codesign_app --app "$app"
      xcrun simctl install "$device" "$app"
    else
      xcrun simctl install "$device" "$app"
    fi
  fi
  local attempt=1
  while [ "$attempt" -le "$retries" ]; do
    if xcrun simctl launch "$device" "$bundle_id" >/dev/null 2>&1; then
      printf 'ok\n'
      return
    fi
    sleep "$retry_delay"
    attempt=$((attempt + 1))
  done
  xcrun simctl launch "$device" "$bundle_id"
}

install_app() {
  local app=""
  local device="booted"
  local sign_mode="retry"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --app)
        shift
        app="${1:-}"
        ;;
      --device)
        shift
        device="${1:-}"
        ;;
      --codesign)
        shift
        sign_mode="${1:-}"
        ;;
      *) fail "unknown install option: $1" ;;
    esac
    shift || true
  done
  require_value '--app' "$app"
  require_value '--device' "$device"
  [ -d "$app" ] || fail "app bundle not found: $app"
  case "$sign_mode" in
    always | retry | never) ;;
    *) fail '--codesign must be always, retry, or never' ;;
  esac
  if [ "$sign_mode" = 'always' ]; then
    codesign_app --app "$app"
  fi
  if ! xcrun simctl install "$device" "$app" >/dev/null 2>&1; then
    if [ "$sign_mode" = 'retry' ]; then
      codesign_app --app "$app"
      xcrun simctl install "$device" "$app"
    else
      xcrun simctl install "$device" "$app"
    fi
  fi
}

