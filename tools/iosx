#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
usage() {
  cat <<'USAGE'
iosx: product-neutral iOS tooling CLI

Commands:
  version
  commands [--json]
  doctor [--fast|--all] [--json]
  device <ios-device args...>
  sim <ios-sim args...>
  xcode <ios-xcode args...>
USAGE
  printf '  path [--json] %s\n' "$(path_usage_targets)"
  cat <<'USAGE'
  lint swift-gates <run-swift-gates args...>
  lint swiftformat <swiftformat args...>
  lint false-green <no-false-green-verify args...>
  lint no-direct-bundle-config <no-direct-bundle-config args...>
  lint no-direct-ios-helper <no-direct-ios-helper args...>
  lint run-all <run-all args...>
  lint dead-code <run-dead-code args...>

Install `iosx` into PATH. Consumer repos should depend on this command name,
not on a developer-machine checkout path.
USAGE
}

fail() {
  printf 'iosx: %s\n' "$1" >&2
  exit 1
}

exec_tool() {
  local tool="$1"
  shift
  [ -x "$tool" ] || fail "missing executable: $tool"
  exec "$tool" "$@"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  printf '%s' "$value"
}

version() {
  git -C "$ROOT" rev-parse --short=12 HEAD 2>/dev/null || printf 'unknown\n'
}

path_specs() {
  cat <<'PATHS'
root .
checkmake-config templates/strict-checkmake.ini
editorconfig-checker-config templates/strict-editorconfig-checker.json
markdownlint-config templates/strict-markdownlint.json
ruff-config templates/strict-ruff.toml
swiftformat-config templates/strict-swiftformat.config
swiftlint-config templates/strict-swiftlint.yml
typos-config _typos.toml
yamllint-config templates/strict-yamllint.yml
PATHS
}

path_usage_targets() {
  local target
  local _relative_path
  local separator=''
  while IFS=' ' read -r target _relative_path; do
    printf '%s%s' "$separator" "$target"
    separator='|'
  done < <(path_specs)
  printf '\n'
}

required_fast_executable_paths() {
  cat <<'PATHS'
tools/ios-device
tools/ios-sim
tools/ios-xcode
tools/lint/run-swift-gates
tools/lint/no-false-green-verify
tools/lint/no-direct-bundle-config
tools/lint/no-direct-ios-helper
tools/lint/run-all
PATHS
}

required_on_demand_executable_paths() {
  cat <<'PATHS'
tools/lint/run-dead-code
PATHS
}

required_file_paths() {
  local target
  local relative_path
  while IFS=' ' read -r target relative_path; do
    [ "$target" = root ] || printf '%s\n' "$relative_path"
  done < <(path_specs)
}

required_fast_external_tools() {
  cat <<'TOOLS'
checkmake
codesign
editorconfig-checker
file
git
ipconfig
jq
lychee
markdownlint-cli2
python3
ruff
security
shellcheck
shfmt
swift
swiftformat
swiftlint
taplo
typos
xcrun
yamllint
TOOLS
}

required_on_demand_external_tools() {
  cat <<'TOOLS'
periphery
TOOLS
}

required_absolute_paths() {
  cat <<'PATHS'
/usr/libexec/PlistBuddy
PATHS
}

doctor() {
  local json=false
  local scope=all
  local missing=()
  local path

  while [ "$#" -gt 0 ]; do
    case "${1:-}" in
      --json)
        json=true
        ;;
      --fast)
        scope=fast
        ;;
      --all)
        scope=all
        ;;
      *)
        fail 'doctor only accepts --fast, --all, and --json'
        ;;
    esac
    shift
  done

  while IFS= read -r path; do
    [ -x "$ROOT/$path" ] || missing+=("$path")
  done < <(required_fast_executable_paths)

  if [ "$scope" = all ]; then
    while IFS= read -r path; do
      [ -x "$ROOT/$path" ] || missing+=("$path")
    done < <(required_on_demand_executable_paths)
  fi

  while IFS= read -r path; do
    [ -f "$ROOT/$path" ] || missing+=("$path")
  done < <(required_file_paths)

  while IFS= read -r path; do
    command -v "$path" >/dev/null 2>&1 || missing+=("tool:$path")
  done < <(required_fast_external_tools)

  if [ "$scope" = all ]; then
    while IFS= read -r path; do
      command -v "$path" >/dev/null 2>&1 || missing+=("tool:$path")
    done < <(required_on_demand_external_tools)
  fi

  while IFS= read -r path; do
    [ -x "$path" ] || missing+=("$path")
  done < <(required_absolute_paths)

  if [ "$json" = true ]; then
    printf '{"ok":'
    if [ "${#missing[@]}" -eq 0 ]; then
      printf 'true'
    else
      printf 'false'
    fi
    printf ',"scope":"%s","root":"%s","version":"%s","missing":[' "$(json_escape "$scope")" "$(json_escape "$ROOT")" "$(json_escape "$(version)")"
    local index
    for index in "${!missing[@]}"; do
      [ "$index" -eq 0 ] || printf ','
      printf '"%s"' "$(json_escape "${missing[$index]}")"
    done
    printf ']}\n'
  fi

  if [ "${#missing[@]}" -ne 0 ]; then
    fail "missing executable: ${missing[0]}"
  fi

  if [ "$json" != true ]; then
    printf 'ok\n'
  fi
}

path_value() {
  local json=false
  if [ "${1:-}" = "--json" ]; then
    json=true
    shift
  fi
  [ "$#" -eq 1 ] || fail 'path requires exactly one target'

  local kind="${1:-}"
  local target
  local relative_path
  local value=''
  while IFS=' ' read -r target relative_path; do
    if [ "$kind" = "$target" ]; then
      if [ "$target" = root ]; then
        value="$ROOT"
      else
        value="$ROOT/$relative_path"
      fi
      break
    fi
  done < <(path_specs)

  if [ -z "$value" ]; then
    usage >&2
    exit 2
  fi

  if [ "$json" = true ]; then
    printf '{"kind":"%s","path":"%s"}\n' "$(json_escape "$kind")" "$(json_escape "$value")"
  else
    printf '%s\n' "$value"
  fi
}

commands() {
  [ "$#" -le 1 ] || fail 'commands accepts at most --json'
  case "${1:-}" in
    --json)
      local targets
      targets="$(path_usage_targets)"
      cat <<JSON
{"commands":[
  {"name":"doctor","usage":"iosx doctor [--fast|--all] [--json]","purpose":"verify the installed substrate CLI can find required reusable helpers; --fast excludes on-demand dead-code tooling"},
  {"name":"version","usage":"iosx version [--json]","purpose":"print the substrate git revision behind this iosx installation"},
  {"name":"path","usage":"iosx path [--json] ${targets}","purpose":"print canonical paths for tools that require config files"},
  {"name":"device","usage":"iosx device <subcommand> [args...]","purpose":"run physical-device and LAN discovery helpers"},
  {"name":"sim","usage":"iosx sim <subcommand> [args...]","purpose":"run simulator boot/install/launch/reset/push helpers"},
  {"name":"xcode","usage":"iosx xcode <subcommand> [args...]","purpose":"create generic Xcode helper artifacts"},
  {"name":"lint swift-gates","usage":"iosx lint swift-gates [--swiftlint-overlay .swiftlint.yml] <swift-root>...","purpose":"run the strict reusable Swift lint bundle"},
  {"name":"lint swiftformat","usage":"iosx lint swiftformat <swiftformat args...>","purpose":"run SwiftFormat with the substrate strict config"},
  {"name":"lint false-green","usage":"iosx lint false-green <path>...","purpose":"reject verification scripts that can hide pipeline failures"},
  {"name":"lint no-direct-bundle-config","usage":"iosx lint no-direct-bundle-config <swift-root>...","purpose":"reject direct Bundle.main Info.plist reads in Swift code"},
  {"name":"lint no-direct-ios-helper","usage":"iosx lint no-direct-ios-helper <path>...","purpose":"reject copied generic iOS helper logic in consumer repos"},
  {"name":"lint run-all","usage":"iosx lint run-all [selector args...]","purpose":"run the substrate fast gate suite"},
  {"name":"lint dead-code","usage":"iosx lint dead-code [args...]","purpose":"run the dedicated on-demand dead-code gate"}
]}
JSON
      ;;
    "")
      usage
      ;;
    *)
      fail 'commands only accepts --json'
      ;;
  esac
}

case "${1:-}" in
  version)
    shift
    case "${1:-}" in
      --json)
        shift
        [ "$#" -eq 0 ] || fail 'version --json does not accept extra options'
        printf '{"version":"%s"}\n' "$(json_escape "$(version)")"
        ;;
      "")
        version
        ;;
      *)
        fail 'version only accepts --json'
        ;;
    esac
    ;;
  commands)
    shift
    commands "$@"
    ;;
  doctor)
    shift
    doctor "$@"
    ;;
  device)
    shift
    exec_tool "$ROOT/tools/ios-device" "$@"
    ;;
  sim)
    shift
    exec_tool "$ROOT/tools/ios-sim" "$@"
    ;;
  xcode)
    shift
    exec_tool "$ROOT/tools/ios-xcode" "$@"
    ;;
  path)
    shift
    path_value "$@"
    ;;
  lint)
    shift
    case "${1:-}" in
      swift-gates)
        shift
        exec_tool "$ROOT/tools/lint/run-swift-gates" "$@"
        ;;
      swiftformat)
        shift
        command -v swiftformat >/dev/null 2>&1 || fail 'missing required tool: swiftformat'
        exec swiftformat --config "$ROOT/templates/strict-swiftformat.config" "$@"
        ;;
      false-green)
        shift
        exec_tool "$ROOT/tools/lint/no-false-green-verify" "$@"
        ;;
      no-direct-bundle-config)
        shift
        exec_tool "$ROOT/tools/lint/no-direct-bundle-config" "$@"
        ;;
      no-direct-ios-helper)
        shift
        exec_tool "$ROOT/tools/lint/no-direct-ios-helper" "$@"
        ;;
      run-all)
        shift
        exec_tool "$ROOT/tools/lint/run-all" "$@"
        ;;
      dead-code)
        shift
        exec_tool "$ROOT/tools/lint/run-dead-code" "$@"
        ;;
      *)
        usage >&2
        exit 2
        ;;
    esac
    ;;
  help | --help | -h)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
