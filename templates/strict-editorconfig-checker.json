{
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": false,
  "NoColor": true,
  "Exclude": [
    ".build/",
    ".git/",
    ".swiftpm/",
    "DerivedData/",
    "build/",
    "Package.resolved"
  ],
