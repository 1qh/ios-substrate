root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{yml,yaml,json,md}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[tools/ios-device]
indent_size = 2

[tools/ios-sim]
indent_size = 2

[tools/ios-xcode]
indent_size = 2

[tools/iosx]
indent_size = 2

[tools/install-local]
indent_size = 2

[tools/lint/run-dead-code]
indent_size = 2

[tools/lint/run-swift-gates]
indent_size = 2

[tools/lint/no-direct-bundle-config]
indent_size = 2

[tools/lint/no-direct-ios-helper]
indent_size = 4
